    <string name="application_info_text">
        <![CDATA[
            <b>ስሪያ</b> %1$s<br>
            <b>ልማት</b> %2$d &#8226; <a href="https://github.com/mxmilkiib/material-hack/commit/%5$s">%5$s</a><br>
            <b>ተሰራ</b> %3$s (%4$s)<br><br>
            <b>Material Hack</b> የ Ha Duy Trung Materialistic ክፍል ነው።<br><br>
            <b>ለውጦች:</b><br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; ዘመነ መሣሪያ<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Gradle 8<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; AGP 8.5<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Kotlin 1.9<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; targetSdk 34<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; አዲስ ገጽቶች<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; ዘጠጣ<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; ውቅያዊ<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; ሮዝ<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Monokai<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Nord<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; አጭር ፊደሎች እና ቀጥታ ክፍተኛ ክፍተኛ አልባበት ዝርዝር ዝርዝር<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; አዲስ ፊደሎች<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Hack Nerd Font<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Inter<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; JetBrains Mono<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Fira Code<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Terminus<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8226;&nbsp; Fixedsys<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; ቀላል የአሰራር ማስታወሻ፣ ሁሉም ክፍሎች በስር<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; በሙሉ መተግበሪያ ውስጥ ቀጥታ ክፍተኛ<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; ግልጽ ኦቨርስክሮል ብርሃን<br>
            &nbsp;&nbsp;&nbsp;&#8226;&nbsp; ጎን በጎን ዲባግ መጫን ድጋፍ<br>
            <br>
            Fork: <a href="https://github.com/mxmilkiib/material-hack">mxmilkiib/material-hack</a><br>
            Original: <a href="https://github.com/hidroh/materialistic">hidroh/materialistic</a>
        ]]>
    </string>
